# Supabase-Zugang (aus dem Supabase-Dashboard -> Project Settings -> API)
# Ohne diese Werte laeuft die App im lokalen Modus (nur dieses Geraet, kein Login).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optionaler Zugangscode fuer die Registrierung.
# Nur wer diesen Code kennt, kann sich ein Konto anlegen. Leer = jeder kann sich registrieren.
VITE_ACCESS_CODE=

# Oeffentlicher VAPID-Key fuer Web-Push (Benachrichtigungen).
# Erzeugen mit: npx web-push generate-vapid-keys  -> "Public Key" hier eintragen.
# Der PRIVATE Key gehoert NICHT hierher, sondern als Secret in die Supabase Edge Function.
VITE_VAPID_PUBLIC_KEY=
